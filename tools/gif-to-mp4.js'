export function renderGifToMp4(tool) {
  const inputs = document.querySelector('#inputs');
  const result = document.querySelector('#result');

  /* ---------------- INPUT UI ---------------- */
  inputs.innerHTML = `
    <div class="form-row">
      <label>Select GIF</label>
      <input
        id="gif_file"
        type="file"
        accept="image/gif"
      />
    </div>

    <div class="form-row">
      <label>Duration (seconds)</label>
      <input
        id="gif_duration"
        type="number"
        min="1"
        value="5"
      />
    </div>

    <button id="gif_convert" class="btn" style="margin-top:6px">
      Convert to MP4
    </button>

    <p class="small muted" style="margin-top:8px">
      Converts GIF to MP4 using browser recording.
    </p>
  `;

  /* ---------------- RESULT UI ---------------- */
  result.innerHTML = `
    <div class="result-box" style="transition:opacity .25s ease">
      <div class="small">Result</div>
      <div
        id="gif_result"
        style="font-size:14px;font-weight:600;opacity:.6">
        No file processed
      </div>

      <div id="gif_preview" style="margin-top:10px"></div>
    </div>
  `;

  /* ---------------- ELEMENTS ---------------- */
  const fileEl = document.querySelector('#gif_file');
  const durationEl = document.querySelector('#gif_duration');
  const resultEl = document.querySelector('#gif_result');
  const previewEl = document.querySelector('#gif_preview');

  /* ---------------- LOGIC ---------------- */
  async function convertGif() {
    const file = fileEl.files[0];
    if (!file) {
      resultEl.innerText = 'Please select a GIF file';
      resultEl.style.opacity = 1;
      return;
    }

    const duration = Number(durationEl.value) || 5;

    const img = new Image();
    img.src = URL.createObjectURL(file);

    img.onload = async () => {
      const canvas = document.createElement('canvas');
      const ctx = canvas.getContext('2d');

      canvas.width = img.width;
      canvas.height = img.height;

      const stream = canvas.captureStream(30);
      let recorder;

      const chunks = [];
      const mime =
        MediaRecorder.isTypeSupported('video/mp4')
          ? 'video/mp4'
          : 'video/webm';

      recorder = new MediaRecorder(stream, { mimeType: mime });

      recorder.ondataavailable = e => chunks.push(e.data);
      recorder.onstop = () => {
        const blob = new Blob(chunks, { type: mime });
        const url = URL.createObjectURL(blob);

        previewEl.innerHTML = `
          <video
            src="${url}"
            controls
            style="max-width:100%;border-radius:6px">
          </video>
          <div style="margin-top:6px">
            <a href="${url}" download="converted-video.${mime.includes('mp4') ? 'mp4' : 'webm'}">
              Download Video
            </a>
          </div>
        `;

        resultEl.innerText = 'Conversion complete';
        resultEl.style.opacity = 1;
      };

      recorder.start();

      const start = performance.now();
      function draw() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        ctx.drawImage(img, 0, 0);
        if (performance.now() - start < duration * 1000) {
          requestAnimationFrame(draw);
        } else {
          recorder.stop();
        }
      }

      draw();
    };

    resultEl.innerText = 'Converting...';
    resultEl.style.opacity = .4;
  }

  /* ---------------- EVENTS ---------------- */
  document
    .querySelector('#gif_convert')
    .addEventListener('click', convertGif);
}
